{
  "name": "coremd-monorepo",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace @coremd/api",
    "dev": "npm run dev --workspace @coremd/api",
    "test": "npm run test --workspace @coremd/api",
    "prisma:generate": "npm run prisma:generate --workspace @coremd/api",
    "prisma:migrate": "npm run prisma:migrate --workspace @coremd/api",
    "prisma:seed": "npm run prisma:seed --workspace @coremd/api"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
